generator client { provider = "prisma-client-js" }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LockMode { Home Hotel Apartment Office Campus }
enum CredentialType { Password Fingerprint Face Card Remote Phone Nfc Admin }
enum AlertSeverity { Info Warning Critical }

model LockDevice {
  id        String   @id @default(cuid())
  name      String
  room      String
  mode      LockMode @default(Apartment)
  isLocked  Boolean  @default(true)
  isOnline  Boolean  @default(true)
  battery   Int      @default(100)
  signal    Int      @default(100)
  firmware  String   @default("1.0.0")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccessCredential {
  id        String         @id @default(cuid())
  lockId    String
  type      CredentialType
  ownerName String
  label     String
  active    Boolean        @default(true)
  schedule  String
  createdAt DateTime       @default(now())
}

model AccessRecord {
  id        String         @id @default(cuid())
  lockId    String
  title     String
  method    CredentialType
  success   Boolean        @default(true)
  createdAt DateTime       @default(now())
}

model LockAlert {
  id        String        @id @default(cuid())
  lockId    String
  title     String
  message   String
  severity  AlertSeverity @default(Info)
  unread    Boolean       @default(true)
  createdAt DateTime      @default(now())
}
